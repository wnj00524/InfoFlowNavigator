<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:InfoFlowNavigator.UI.ViewModels"
        x:Class="InfoFlowNavigator.UI.Views.MainWindow"
        x:DataType="vm:ShellViewModel"
        Width="1180"
        Height="780"
        MinWidth="980"
        MinHeight="680"
        Title="{Binding Title}"
        mc:Ignorable="d"
        d:DesignWidth="1180"
        d:DesignHeight="780">
  <Grid RowDefinitions="Auto,Auto,*" Margin="20">
    <StackPanel Spacing="6">
      <TextBlock FontSize="30"
                 FontWeight="SemiBold"
                 Text="{Binding Title}" />
      <TextBlock Foreground="#52606D"
                 FontSize="16"
                 Text="{Binding Subtitle}" />
    </StackPanel>

    <Border Grid.Row="1"
            Margin="0,18,0,18"
            Padding="14"
            Background="#E7EEF7"
            CornerRadius="10">
      <TextBlock Text="{Binding StatusMessage}"
                 TextWrapping="Wrap" />
    </Border>

    <Grid Grid.Row="2" ColumnDefinitions="360,*" ColumnSpacing="18">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="16">
          <Border Padding="16" Background="#F8FAFC" CornerRadius="12">
            <StackPanel Spacing="10">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="Workspace" />
              <TextBlock Text="Name" />
              <TextBox Text="{Binding WorkspaceName}" PlaceholderText="Workspace name" />
              <TextBlock Text="Path" />
              <TextBox Text="{Binding WorkspacePath}" PlaceholderText="workspace.ifn.json" />
              <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Button Content="New" Click="CreateNewWorkspace_Click" />
                <Button Grid.Column="1" Content="Open" Click="OpenWorkspace_Click" />
                <Button Grid.Column="2" Content="Save" Click="SaveWorkspace_Click" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Padding="16" Background="#FFF9ED" CornerRadius="12">
            <StackPanel Spacing="10">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="Add Entity" />
              <TextBlock Text="Name" />
              <TextBox Text="{Binding EntityName}" PlaceholderText="Acme Corp" />
              <TextBlock Text="Type" />
              <TextBox Text="{Binding EntityType}" PlaceholderText="Organization" />
              <Button Content="Add Entity" Click="AddEntity_Click" />
            </StackPanel>
          </Border>

          <Border Padding="16" Background="#F3F0FF" CornerRadius="12">
            <StackPanel Spacing="10">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="Add Relationship" />
              <TextBlock Text="Source" />
              <ComboBox ItemsSource="{Binding RelationshipEntityOptions}"
                        SelectedItem="{Binding SelectedSourceEntity}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:EntityOptionViewModel">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Text="Target" />
              <ComboBox ItemsSource="{Binding RelationshipEntityOptions}"
                        SelectedItem="{Binding SelectedTargetEntity}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:EntityOptionViewModel">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Text="Type" />
              <TextBox Text="{Binding RelationshipType}" PlaceholderText="connected_to" />
              <Button Content="Add Relationship" Click="AddRelationship_Click" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" RowSpacing="18">
        <Border Padding="16" Background="#112B3C" CornerRadius="12">
          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Text="{Binding WorkspaceName}" />
            <TextBlock Grid.Column="1"
                       HorizontalAlignment="Right"
                       Foreground="#D9E2EC"
                       Text="{Binding Workspace.SchemaVersion, StringFormat='Schema v{0}'}" />
            <TextBlock Grid.Row="1"
                       Margin="0,8,0,0"
                       Foreground="#D9E2EC"
                       Text="{Binding WorkspaceId, StringFormat='Id: {0}'}" />
            <TextBlock Grid.Row="2"
                       Margin="0,8,0,0"
                       Foreground="#9FB3C8"
                       Text="{Binding WorkspaceUpdatedAt, StringFormat='Updated: {0}'}" />
          </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="18">
          <Border Padding="16" Background="#F8FAFC" CornerRadius="12">
            <StackPanel Spacing="8">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="Workspace Snapshot" />
              <TextBlock Text="{Binding WorkspaceCreatedAt, StringFormat='Created: {0}'}" />
              <TextBlock Text="{Binding WorkspaceEntityCount, StringFormat='Entities: {0}'}" />
              <TextBlock Text="{Binding WorkspaceRelationshipCount, StringFormat='Relationships: {0}'}" />
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Padding="16" Background="#F8FAFC" CornerRadius="12">
            <StackPanel Spacing="8">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="Slice Boundaries" />
              <TextBlock Text="JSON workspace persistence" />
              <TextBlock Text="Entity and relationship editing" />
              <TextBlock Text="No graph, timeline, or importer workflows yet" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="18">
          <Border Padding="16" Background="#FFFFFF" CornerRadius="12">
            <StackPanel Spacing="10">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="Entities" />
              <ItemsControl ItemsSource="{Binding Entities}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:EntitySummaryViewModel">
                    <Border Margin="0,0,0,8" Padding="10" Background="#F8FAFC" CornerRadius="8">
                      <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                        <TextBlock FontSize="12"
                                   Foreground="#52606D"
                                   Text="{Binding Id, StringFormat='Id: {0}'}"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Padding="16" Background="#FFFFFF" CornerRadius="12">
            <StackPanel Spacing="10">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="Relationships" />
              <ItemsControl ItemsSource="{Binding Relationships}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:RelationshipSummaryViewModel">
                    <Border Margin="0,0,0,8" Padding="10" Background="#F8FAFC" CornerRadius="8">
                      <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" TextWrapping="Wrap" />
                        <TextBlock FontSize="12"
                                   Foreground="#52606D"
                                   Text="{Binding Id, StringFormat='Id: {0}'}"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </Grid>
  </Grid>
</Window>
