<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:InfoFlowNavigator.UI.ViewModels"
        x:Class="InfoFlowNavigator.UI.Views.MainWindow"
        x:DataType="vm:ShellViewModel"
        Width="1280"
        Height="860"
        MinWidth="1080"
        MinHeight="740"
        Title="{Binding Title}"
        Background="#F3F6FB"
        Foreground="#14213D"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="860">
  <Window.Styles>
    <Style Selector="TextBlock.section-title">
      <Setter Property="Foreground" Value="#14213D" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="Foreground" Value="#243B53" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="#486581" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="#1F5AA6" />
      <Setter Property="BorderBrush" Value="#174987" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Foreground" Value="#16324F" />
      <Setter Property="Background" Value="#DCE8F5" />
      <Setter Property="BorderBrush" Value="#9FB9D4" />
    </Style>
    <Style Selector="Button.accent">
      <Setter Property="Background" Value="#0F766E" />
      <Setter Property="BorderBrush" Value="#0B5D57" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#B42318" />
      <Setter Property="BorderBrush" Value="#912018" />
    </Style>
    <Style Selector="TextBox, ComboBox, ListBox">
      <Setter Property="Foreground" Value="#14213D" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#9FB3C8" />
      <Setter Property="BorderThickness" Value="1.5" />
    </Style>
    <Style Selector="ListBox">
      <Setter Property="MinHeight" Value="120" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,*" Margin="20">
    <StackPanel Spacing="6">
      <TextBlock FontSize="30"
                 FontWeight="SemiBold"
                 Text="{Binding Title}" />
      <TextBlock Classes="muted"
                 FontSize="16"
                 Text="{Binding Subtitle}" />
    </StackPanel>

    <Border Grid.Row="1"
            Margin="0,18,0,18"
            Padding="14"
            Background="#DCE8F5"
            BorderBrush="#B8CCE3"
            BorderThickness="1"
            CornerRadius="10">
      <TextBlock Foreground="#16324F"
                 FontWeight="SemiBold"
                 Text="{Binding StatusMessage}"
                 TextWrapping="Wrap" />
    </Border>

    <Grid Grid.Row="2" ColumnDefinitions="360,*" ColumnSpacing="18">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="16">
          <Border Padding="16" Background="#FFFFFF" BorderBrush="#D9E2EC" BorderThickness="1" CornerRadius="12">
            <StackPanel Spacing="10">
              <TextBlock Classes="section-title" FontSize="18" Text="Workspace" />
              <TextBlock Classes="label" Text="Name" />
              <TextBox Text="{Binding WorkspaceName}" PlaceholderText="Workspace name" />
              <TextBlock Classes="label" Text="Path" />
              <TextBox Text="{Binding WorkspacePath}" PlaceholderText="workspace.ifn.json" />
              <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Button Classes="secondary" Content="New" Click="CreateNewWorkspace_Click" />
                <Button Grid.Column="1" Classes="secondary" Content="Open" Click="OpenWorkspace_Click" />
                <Button Grid.Column="2" Classes="accent" Content="Save" Click="SaveWorkspace_Click" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Padding="16" Background="#FFF8E8" BorderBrush="#EBCB8B" BorderThickness="1" CornerRadius="12">
            <StackPanel Spacing="10">
              <TextBlock Classes="section-title" FontSize="18" Text="Add Entity" />
              <TextBlock Classes="label" Text="Name" />
              <TextBox Text="{Binding EntityName}" PlaceholderText="Acme Corp" />
              <TextBlock Classes="label" Text="Type" />
              <TextBox Text="{Binding EntityType}" PlaceholderText="Organization" />
              <Button Content="Add Entity" Click="AddEntity_Click" />
            </StackPanel>
          </Border>

          <Border Padding="16" Background="#EAF2FF" BorderBrush="#B8CCE3" BorderThickness="1" CornerRadius="12">
            <StackPanel Spacing="10">
              <TextBlock Classes="section-title" FontSize="18" Text="Add Relationship" />
              <TextBlock Classes="label" Text="Source" />
              <ComboBox ItemsSource="{Binding RelationshipEntityOptions}"
                        SelectedItem="{Binding SelectedSourceEntity}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:EntityOptionViewModel">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Classes="label" Text="Target" />
              <ComboBox ItemsSource="{Binding RelationshipEntityOptions}"
                        SelectedItem="{Binding SelectedTargetEntity}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:EntityOptionViewModel">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Classes="label" Text="Type" />
              <TextBox Text="{Binding RelationshipType}" PlaceholderText="connected_to" />
              <Button Classes="accent" Content="Add Relationship" Click="AddRelationship_Click" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="18">
          <Border Padding="16" Background="#112B3C" CornerRadius="12">
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
              <TextBlock FontSize="22"
                         FontWeight="SemiBold"
                         Foreground="White"
                         Text="{Binding WorkspaceName}" />
              <TextBlock Grid.Column="1"
                         HorizontalAlignment="Right"
                         Foreground="#D9E2EC"
                         Text="{Binding Workspace.SchemaVersion, StringFormat='Schema v{0}'}" />
              <TextBlock Grid.Row="1"
                         Margin="0,8,0,0"
                         Foreground="#D9E2EC"
                         Text="{Binding WorkspaceId, StringFormat='Id: {0}'}" />
              <TextBlock Grid.Row="2"
                         Margin="0,8,0,0"
                         Foreground="#9FB3C8"
                         Text="{Binding WorkspaceUpdatedAt, StringFormat='Updated: {0}'}" />
            </Grid>
          </Border>

          <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
            <Border Padding="16" Background="#FFFFFF" BorderBrush="#D9E2EC" BorderThickness="1" CornerRadius="12">
              <StackPanel Spacing="8">
                <TextBlock Classes="section-title" FontSize="18" Text="Workspace Snapshot" />
                <TextBlock Foreground="#243B53" Text="{Binding WorkspaceCreatedAt, StringFormat='Created: {0}'}" />
                <TextBlock Foreground="#243B53" Text="{Binding WorkspaceEntityCount, StringFormat='Entities: {0}'}" />
                <TextBlock Foreground="#243B53" Text="{Binding WorkspaceRelationshipCount, StringFormat='Relationships: {0}'}" />
                <TextBlock Foreground="#243B53" Text="{Binding WorkspaceEvidenceCount, StringFormat='Evidence: {0}'}" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="16" Background="#FFFFFF" BorderBrush="#D9E2EC" BorderThickness="1" CornerRadius="12">
              <StackPanel Spacing="8">
                <TextBlock Classes="section-title" FontSize="18" Text="Slice Boundaries" />
                <TextBlock Foreground="#243B53" Text="JSON workspace persistence" />
                <TextBlock Foreground="#243B53" Text="Entity editing and deletion" />
                <TextBlock Foreground="#243B53" Text="Relationship and evidence maintenance in-shell" TextWrapping="Wrap" />
                <TextBlock Foreground="#243B53" Text="No graph, timeline, or GraphML workflows in this slice" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </Grid>

          <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
            <Border Padding="16" Background="#FFFFFF" BorderBrush="#D9E2EC" BorderThickness="1" CornerRadius="12">
              <StackPanel Spacing="10">
                <TextBlock Classes="section-title" FontSize="18" Text="Entities" />
                <ListBox ItemsSource="{Binding Entities}"
                         SelectedItem="{Binding SelectedEntity}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:EntitySummaryViewModel">
                      <Border Margin="0,0,0,8" Padding="10" Background="#EEF4FB" BorderBrush="#D9E2EC" BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                          <TextBlock FontWeight="SemiBold" Foreground="#14213D" Text="{Binding DisplayName}" />
                          <TextBlock FontSize="12"
                                     Foreground="#486581"
                                     Text="{Binding Id, StringFormat='Id: {0}'}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="16" Background="#FFFFFF" BorderBrush="#D9E2EC" BorderThickness="1" CornerRadius="12">
              <StackPanel Spacing="10">
                <TextBlock Classes="section-title" FontSize="18" Text="Edit Selected Entity" />
                <TextBlock Classes="muted" Text="Choose an entity from the list to edit or delete it." TextWrapping="Wrap" />
                <TextBlock Classes="label" Text="Name" />
                <TextBox Text="{Binding EditableEntityName}" PlaceholderText="Entity name" />
                <TextBlock Classes="label" Text="Type" />
                <TextBox Text="{Binding EditableEntityType}" PlaceholderText="Entity type" />
                <TextBlock Classes="label" Text="Notes" />
                <TextBox Text="{Binding EditableEntityNotes}"
                         AcceptsReturn="True"
                         Height="96"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top" />
                <TextBlock Classes="label" Text="Confidence" />
                <TextBox Text="{Binding EditableEntityConfidenceText}" PlaceholderText="0.0 to 1.0" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                  <Button Classes="accent" Content="Save Entity" Click="UpdateEntity_Click" />
                  <Button Grid.Column="1" Classes="danger" Content="Delete Entity" Click="DeleteEntity_Click" />
                </Grid>
              </StackPanel>
            </Border>
          </Grid>

          <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
            <Border Padding="16" Background="#FFFFFF" BorderBrush="#D9E2EC" BorderThickness="1" CornerRadius="12">
              <StackPanel Spacing="10">
                <TextBlock Classes="section-title" FontSize="18" Text="Relationships" />
                <ListBox ItemsSource="{Binding Relationships}"
                         SelectedItem="{Binding SelectedRelationship}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:RelationshipSummaryViewModel">
                      <Border Margin="0,0,0,8" Padding="10" Background="#EEF4FB" BorderBrush="#D9E2EC" BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                          <TextBlock FontWeight="SemiBold" Foreground="#14213D" Text="{Binding DisplayName}" TextWrapping="Wrap" />
                          <TextBlock FontSize="12"
                                     Foreground="#486581"
                                     Text="{Binding Id, StringFormat='Id: {0}'}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <Button Classes="danger" Content="Delete Selected Relationship" Click="DeleteRelationship_Click" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="16" Background="#FFFFFF" BorderBrush="#D9E2EC" BorderThickness="1" CornerRadius="12">
              <StackPanel Spacing="10">
                <TextBlock Classes="section-title" FontSize="18" Text="Evidence" />
                <ListBox ItemsSource="{Binding EvidenceItems}"
                         SelectedItem="{Binding SelectedEvidence}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:EvidenceSummaryViewModel">
                      <Border Margin="0,0,0,8" Padding="10" Background="#EEF4FB" BorderBrush="#D9E2EC" BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                          <TextBlock FontWeight="SemiBold" Foreground="#14213D" Text="{Binding DisplayName}" />
                          <TextBlock FontSize="12"
                                     Foreground="#486581"
                                     Text="{Binding Citation}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Classes="label" Text="Title" />
                <TextBox Text="{Binding EvidenceTitle}" PlaceholderText="Evidence title" />
                <TextBlock Classes="label" Text="Citation" />
                <TextBox Text="{Binding EvidenceCitation}" PlaceholderText="Document, URL, or source reference" />
                <TextBlock Classes="label" Text="Notes" />
                <TextBox Text="{Binding EvidenceNotes}"
                         AcceptsReturn="True"
                         Height="96"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top" />
                <TextBlock Classes="label" Text="Confidence" />
                <TextBox Text="{Binding EvidenceConfidenceText}" PlaceholderText="0.0 to 1.0" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                  <Button Classes="accent" Content="{Binding EvidenceActionLabel}" Click="SaveEvidence_Click" />
                  <Button Grid.Column="1" Classes="danger" Content="Delete Evidence" Click="DeleteEvidence_Click" />
                </Grid>
              </StackPanel>
            </Border>
          </Grid>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</Window>
