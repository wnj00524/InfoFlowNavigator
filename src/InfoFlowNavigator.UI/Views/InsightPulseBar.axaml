<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InfoFlowNavigator.UI.ViewModels"
             x:Class="InfoFlowNavigator.UI.Views.InsightPulseBar"
             x:DataType="vm:WorkspaceShellViewModel">
  <UserControl.Styles>
    <StyleInclude Source="avares://InfoFlowNavigator.UI/Views/ShellStyles.axaml" />
  </UserControl.Styles>

  <ItemsControl ItemsSource="{Binding InsightPulseItems}">
    <ItemsControl.ItemsPanel>
      <ItemsPanelTemplate>
        <WrapPanel Orientation="Horizontal" />
      </ItemsPanelTemplate>
    </ItemsControl.ItemsPanel>
    <ItemsControl.ItemTemplate>
      <DataTemplate x:DataType="vm:InsightPulseItemViewModel">
        <Border Classes="pulse-card" Margin="0,0,10,10" Width="260">
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Classes="badge-pill">
                <TextBlock Text="{Binding Severity}" />
              </Border>
              <TextBlock Classes="label" Text="{Binding Title}" TextWrapping="Wrap" />
            </StackPanel>
            <TextBlock Classes="muted" Text="{Binding Detail}" TextWrapping="Wrap" />
            <TextBlock Classes="subtle"
                       Text="{Binding TargetSection, StringFormat='Focus: {0}'}"
                       IsVisible="{Binding IsActionable}" />
          </StackPanel>
        </Border>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>
</UserControl>
