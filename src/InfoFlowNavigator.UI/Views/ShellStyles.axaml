<Styles xmlns="https://github.com/avaloniaui">
  <Style Selector="Window">
    <Setter Property="Background" Value="#081524" />
    <Setter Property="Foreground" Value="#DCE8F3" />
  </Style>

  <Style Selector="Border.shell-panel">
    <Setter Property="Background" Value="#0E1C2F" />
    <Setter Property="BorderBrush" Value="#20364F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="22" />
  </Style>

  <Style Selector="Border.hero-card">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Offset="0" Color="#16304D" />
        <GradientStop Offset="0.55" Color="#10253D" />
        <GradientStop Offset="1" Color="#0A1829" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="BorderBrush" Value="#31506F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="24" />
    <Setter Property="Padding" Value="24" />
  </Style>

  <Style Selector="Border.panel-card">
    <Setter Property="Background" Value="#102137" />
    <Setter Property="BorderBrush" Value="#20364F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="20" />
  </Style>

  <Style Selector="Border.rail-card">
    <Setter Property="Background" Value="#102137" />
    <Setter Property="BorderBrush" Value="#20364F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="Padding" Value="20" />
  </Style>

  <Style Selector="Border.canvas-card">
    <Setter Property="Background" Value="#102137" />
    <Setter Property="BorderBrush" Value="#20364F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="Padding" Value="20" />
  </Style>

  <Style Selector="Border.drawer-card">
    <Setter Property="Background" Value="#102137" />
    <Setter Property="BorderBrush" Value="#20364F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="Padding" Value="20" />
  </Style>

  <Style Selector="Border.spotlight-card">
    <Setter Property="Background" Value="#102137" />
    <Setter Property="BorderBrush" Value="#20364F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="Padding" Value="20" />
  </Style>

  <Style Selector="Border.metric-card">
    <Setter Property="Background" Value="#102137" />
    <Setter Property="BorderBrush" Value="#20364F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style Selector="Border.pulse-card">
    <Setter Property="Background" Value="#102137" />
    <Setter Property="BorderBrush" Value="#20364F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Border.toast-card">
    <Setter Property="Background" Value="#102137" />
    <Setter Property="BorderBrush" Value="#20364F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Border.badge-pill">
    <Setter Property="Background" Value="#132C45" />
    <Setter Property="BorderBrush" Value="#2B4764" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="12,7" />
  </Style>

  <Style Selector="TextBlock.page-title">
    <Setter Property="FontSize" Value="26" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="#F6FAFD" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="#F6FAFD" />
  </Style>

  <Style Selector="TextBlock.subtle">
    <Setter Property="Foreground" Value="#8AA6C1" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="#8AA6C1" />
  </Style>

  <Style Selector="TextBlock.label">
    <Setter Property="Foreground" Value="#D6E6F5" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Foreground" Value="#06111F" />
    <Setter Property="Background" Value="#7EE0C3" />
    <Setter Property="BorderBrush" Value="#67C4A8" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="#95E8CF" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="#6BCFB0" />
  </Style>

  <Style Selector="Button.secondary">
    <Setter Property="Foreground" Value="#DCE8F3" />
    <Setter Property="Background" Value="#17304C" />
    <Setter Property="BorderBrush" Value="#2B4764" />
  </Style>

  <Style Selector="Button.secondary:pointerover">
    <Setter Property="Background" Value="#1C3958" />
  </Style>

  <Style Selector="Button.ghost">
    <Setter Property="Foreground" Value="#DCE8F3" />
    <Setter Property="Background" Value="#0F2137" />
    <Setter Property="BorderBrush" Value="#27425F" />
  </Style>

  <Style Selector="Button.ghost:pointerover">
    <Setter Property="Background" Value="#17304C" />
  </Style>

  <Style Selector="Button.danger">
    <Setter Property="Foreground" Value="White" />
    <Setter Property="Background" Value="#BF4D4D" />
    <Setter Property="BorderBrush" Value="#A64141" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Foreground" Value="#F6FAFD" />
    <Setter Property="Background" Value="#09182A" />
    <Setter Property="BorderBrush" Value="#2B4764" />
    <Setter Property="BorderThickness" Value="1.5" />
    <Setter Property="CornerRadius" Value="14" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Foreground" Value="#F6FAFD" />
    <Setter Property="Background" Value="#09182A" />
    <Setter Property="BorderBrush" Value="#2B4764" />
    <Setter Property="BorderThickness" Value="1.5" />
    <Setter Property="CornerRadius" Value="14" />
  </Style>

  <Style Selector="ListBox">
    <Setter Property="Foreground" Value="#F6FAFD" />
    <Setter Property="Background" Value="#09182A" />
    <Setter Property="BorderBrush" Value="#2B4764" />
    <Setter Property="BorderThickness" Value="1.5" />
    <Setter Property="CornerRadius" Value="14" />
  </Style>

  <Style Selector="TextBox:pointerover">
    <Setter Property="BorderBrush" Value="#487196" />
  </Style>

  <Style Selector="ComboBox:pointerover">
    <Setter Property="BorderBrush" Value="#487196" />
  </Style>

  <Style Selector="ListBox:pointerover">
    <Setter Property="BorderBrush" Value="#487196" />
  </Style>

  <Style Selector="TextBox:focus">
    <Setter Property="BorderBrush" Value="#7EE0C3" />
  </Style>

  <Style Selector="ComboBox:focus">
    <Setter Property="BorderBrush" Value="#7EE0C3" />
  </Style>

  <Style Selector="ListBox:focus">
    <Setter Property="BorderBrush" Value="#7EE0C3" />
  </Style>

  <Style Selector="ListBox.nav-rail">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ListBox.nav-rail ListBoxItem">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0,0,0,10" />
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Foreground" Value="#DCE8F3" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBoxItem:pointerover">
    <Setter Property="Background" Value="#132C45" />
  </Style>

  <Style Selector="ListBoxItem:selected">
    <Setter Property="Background" Value="#17304C" />
    <Setter Property="BorderBrush" Value="#7EE0C3" />
  </Style>

  <Style Selector="ScrollViewer">
    <Setter Property="Background" Value="Transparent" />
  </Style>
</Styles>
